# Application
NODE_ENV=development
APP_PORT=4973

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=errortracer

# Auth
JWT_SECRET=replace-me
ACCESS_TOKEN_SECRET=replace-me
REFRESH_TOKEN_SECRET=replace-me

# Logging
# Local development defaults to pretty console logs when LOG_FORMAT is unset.
# Production defaults to JSON console logs when LOG_FORMAT is unset.
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_DIR=logs
LOG_ERROR_FILE=error.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
