# Application
NODE_ENV=development
APP_PORT=4973
APP_KEY_GENERATOR=replace

# PostgreSQL
DB_HOST=replace
DB_PORT=replace
DB_USER=replace
DB_PASSWORD=replace
DB_NAME=replace

# Auth
JWT_SECRET=replace
ACCESS_TOKEN_SECRET=replace
REFRESH_TOKEN_SECRET=replace

# Logging
# Local development defaults to pretty console logs when LOG_FORMAT is unset.
# Production defaults to JSON console logs when LOG_FORMAT is unset.
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_DIR=logs
LOG_ERROR_FILE=error.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# Docker Compose Configurations
DIRECTORY_BACKEND=
DIRECTORY_FRONTEND=
